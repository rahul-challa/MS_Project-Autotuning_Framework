# MacSim Configuration File
# Generated for workload: w6_branch_intensive

# Simulation Configuration
num_sim_cores 1
num_sim_small_cores 0
num_sim_medium_cores 0
num_sim_large_cores 1
core_type x86
large_core_type x86
sim_cycle_count 0
max_insts 10000000
heartbeat_interval 1000000
forward_progress_limit 50000

# Clock
clock_cpu 4

# Common Core Configuration
fetch_policy rr
mt_no_fetch_br 1
one_cycle_exec 0

# Large Core Configuration (x86)
large_width 4
large_core_fetch_latency 5
large_core_alloc_latency 10
isched_large_rate 4
msched_large_rate 2
fsched_large_rate 2
bp_hist_length 16
rob_large_size 128
large_core_schedule ooo
max_threads_per_large_core 1
icache_large_num_set 64
icache_large_assoc 8
l1_large_num_set 64
l1_large_assoc 8
l1_large_latency 3
l1_large_bypass 0
l2_large_num_set 256
l2_large_assoc 8
l2_large_latency 12
l2_large_bypass 0

# LLC Cache Configuration
num_llc 4
llc_num_set 1024
llc_line_size 64
llc_assoc 32
llc_num_bank 8
llc_latency 30
pref_framework_on 1
enable_pref_small_core 0

# Memory Configuration
perfect_dcache 0
enable_cache_coherence 0
memory_type llc_decoupled_network
